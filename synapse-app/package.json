{
  "name": "synapse-app",
  "private": true,
  "version": "0.1.0",
  "description": "Synapse — AI驱动的交互式学习平台",
  "author": "Stardust",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:build && concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:pack": "npm run build && npm run electron:build && electron-builder",
    "clean": "rimraf dist dist-electron"
  },
  "build": {
    "appId": "com.synapse.app",
    "productName": "Synapse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/katex": "^0.16.8",
    "better-sqlite3": "^12.9.0",
    "katex": "^0.16.40",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.13.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.7.5",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
